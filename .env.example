# InstaSum-Image — environment variables
# Copy this file to .env and fill in your keys,
# OR paste keys directly in the app (they'll be saved to ~/.config/instasum/config.env).

# OpenAI key — required if using OpenAI provider
OPENAI_API_KEY=sk-...

# Google Gemini key — required if using Gemini provider
GEMINI_API_KEY=AIza...
